---
// Reusable layout for service category pages.
// Props:
//   slug, title, kicker, intro, longDescription, services[]
import Layout from '~/layouts/PageLayout.astro';

interface Service {
  title: string;
  desc: string;
}

export interface Props {
  slug: string;
  title: string;
  kicker: string;
  intro: string;
  longDescription: string;
  services: Service[];
  metaDescription: string;
  whyUs?: { title: string; desc: string }[];
  faqs?: { q: string; a: string }[];
}

const { slug, title, kicker, intro, longDescription, services, metaDescription, whyUs = [], faqs = [] } = Astro.props;

const metadata = {
  title: title + ' | Mississauga & GTA',
  description: metaDescription,
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: metaDescription,
  serviceType: title,
  provider: {
    '@type': 'HomeAndConstructionBusiness',
    '@id': 'https://quickfast.ca/#business',
    name: 'QuickFast Service Company',
  },
  areaServed: ['Mississauga', 'Toronto', 'Etobicoke', 'Oakville', 'Brampton', 'Vaughan'].map((c) => ({
    '@type': 'City',
    name: c,
  })),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: title + ' options',
    itemListElement: services.map((s) => ({ '@type': 'Offer', name: s.title })),
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://quickfast.ca/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://quickfast.ca/services/' },
    { '@type': 'ListItem', position: 3, name: title, item: 'https://quickfast.ca/services/' + slug + '/' },
  ],
};

const howTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to book ' + title.toLowerCase() + ' with QuickFast Service Company',
  description: 'Our standard four-step process for ' + title.toLowerCase() + '.',
  totalTime: 'P1D',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Request an estimate', text: 'Call or submit our online form — we respond within one business hour.' },
    { '@type': 'HowToStep', position: 2, name: 'Site visit + quote', text: 'We inspect on-site and provide a written fixed-price quote within 24 hours.' },
    { '@type': 'HowToStep', position: 3, name: 'Schedule the work', text: 'We schedule the work at a time that works for you, including same-day service when available.' },
    { '@type': 'HowToStep', position: 4, name: 'Complete + follow up', text: 'We complete the work, walk you through the result, and follow up within 7 days.' },
  ],
};

const faqSchema =
  faqs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
      }
    : null;
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema).replace(/</g, '\\u003c')} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb).replace(/</g, '\\u003c')} />
    <script type="application/ld+json" set:html={JSON.stringify(howTo).replace(/</g, '\\u003c')} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema).replace(/</g, '\\u003c')} />}
  </Fragment>

  <section class="relative min-h-[55vh] flex items-center overflow-hidden" style="background: linear-gradient(135deg, #112F5B 0%, #0a1f40 100%);">
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-[10%] right-[5%] w-[400px] h-[400px] rounded-full opacity-[0.18] blur-[100px]" style="background: radial-gradient(circle, #116DFF, transparent 70%); animation: drift 22s ease-in-out infinite alternate;"></div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center pt-32 pb-12">
      <p class="hero-fade text-xs font-bold uppercase tracking-[0.2em] text-blue-300 mb-3">{kicker}</p>
      <h1 class="hero-fade text-4xl sm:text-5xl lg:text-6xl font-serif font-bold text-white leading-tight" style="animation-delay:120ms">
        {title}
      </h1>
      <p class="hero-fade lead mt-6 text-lg text-gray-200 max-w-2xl mx-auto" style="animation-delay:280ms">{intro}</p>
      <div class="hero-fade mt-8 flex flex-col sm:flex-row items-center justify-center gap-3" style="animation-delay:440ms">
        <a href="/contact/" data-open-request-dialog class="btn-primary">Request a quote</a>
        <a href="tel:+14166293213" class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-7 py-3.5 text-base font-semibold text-white hover:bg-white/10 transition">+1 416-629-3213</a>
      </div>
    </div>
  </section>

  {/* Long description / process intro */}
  <section class="py-16 lg:py-20 bg-page">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="prose prose-lg max-w-none" data-animate>
        <h2 class="text-3xl font-serif font-bold text-heading mb-4">What we do</h2>
        <p class="text-lg text-default leading-relaxed" set:html={longDescription}></p>
      </div>
    </div>
  </section>

  {/* Services in this category */}
  <section class="py-16 lg:py-20 bg-page bg-dots">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12" data-animate>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">All Services</p>
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-heading">Specific {title.toLowerCase()} services</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {services.map((s, i) => (
          <div class="card" data-animate style={`animation-delay: ${i * 50}ms`}>
            <h3 class="text-lg font-serif font-bold text-heading mb-2">{s.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {whyUs.length > 0 && (
    <section class="relative py-16 lg:py-20 overflow-hidden" style="background: linear-gradient(135deg, #112F5B 0%, #0a1f40 100%);">
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>
      <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12" data-animate>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-blue-300 mb-3">Why QuickFast</p>
          <h2 class="text-3xl sm:text-4xl font-serif font-bold text-white">Reasons to call us first</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
          {whyUs.map((w, i) => (
            <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6 hover:bg-white/10 transition" data-animate style={`animation-delay: ${i * 100}ms`}>
              <h3 class="text-lg font-bold text-white mb-2">{w.title}</h3>
              <p class="text-sm text-gray-300 leading-relaxed">{w.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Process — HowTo schema reflected here */}
  <section class="py-16 lg:py-20 bg-page">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12" data-animate>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">Our Process</p>
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-heading">How we work — every job</h2>
      </div>
      <ol class="space-y-4">
        {[
          { step: 1, name: 'Request an estimate', text: 'Call or submit our online form — we respond within one business hour.' },
          { step: 2, name: 'Site visit + written quote', text: 'We inspect on-site and deliver a written fixed-price quote within 24 hours.' },
          { step: 3, name: 'Schedule the work', text: 'We book a time that works for you. Same-day service available for most jobs.' },
          { step: 4, name: 'Complete + follow up', text: 'We finish to spec, walk you through the result, and follow up within 7 days.' },
        ].map((s, i) => (
          <li class="flex items-start gap-4 card" data-animate style={`animation-delay: ${i * 80}ms`}>
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center font-serif font-bold text-xl">{s.step}</div>
            <div>
              <h3 class="text-lg font-serif font-bold text-heading mb-1">{s.name}</h3>
              <p class="text-default text-sm leading-relaxed">{s.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {faqs.length > 0 && (
    <section class="py-16 lg:py-20 bg-page bg-dots">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12" data-animate>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">FAQ</p>
          <h2 class="text-3xl sm:text-4xl font-serif font-bold text-heading">Common questions</h2>
        </div>
        <div class="space-y-3">
          {faqs.map((f, i) => (
            <details class="group rounded-xl border border-secondary/10 bg-white p-5 transition hover:border-primary/30 hover:shadow-md" data-animate style={`animation-delay: ${i * 60}ms`}>
              <summary class="cursor-pointer list-none flex items-start justify-between gap-4">
                <h3 class="text-base sm:text-lg font-semibold text-heading">{f.q}</h3>
                <svg class="w-5 h-5 text-primary flex-shrink-0 mt-1 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
              </summary>
              <p class="mt-3 text-default leading-relaxed">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="relative overflow-hidden py-20" style="background: radial-gradient(ellipse at 50% 40%, #1a3a5c 0%, #0F172A 70%);">
    <div class="absolute top-[-10%] left-[10%] w-[400px] h-[400px] rounded-full opacity-[0.18] blur-[100px]" style="background: radial-gradient(circle, #116DFF, transparent 70%); animation: drift 18s ease-in-out infinite alternate;"></div>
    <div class="relative z-10 max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-serif font-bold text-white" data-animate>
        Get a free quote on {title.toLowerCase()}
      </h2>
      <p class="mt-4 text-lg text-gray-300" data-animate>We respond within 1 business hour. No high-pressure sales.</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3" data-animate>
        <a href="/contact/" data-open-request-dialog class="btn-primary">Request Service</a>
        <a href="tel:+14166293213" class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-9 py-4 text-base font-semibold text-white hover:bg-white/10 transition">Call +1 416-629-3213</a>
      </div>
    </div>
  </section>
</Layout>
