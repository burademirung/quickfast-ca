---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    /* Typography — serif for headings (trade default), Inter Variable for body */
    --aw-font-sans: 'Inter Variable', system-ui, -apple-system, sans-serif;
    --aw-font-serif: Georgia, 'Times New Roman', serif;
    --aw-font-heading: Georgia, 'Times New Roman', serif;

    /* Channel-only RGB triplets (for Tailwind opacity modifiers) */
    --aw-color-primary-rgb: 17 109 255;          /* #116DFF — bright trade blue */
    --aw-color-secondary-rgb: 17 47 91;          /* #112F5B — deep navy */
    --aw-color-accent-rgb: 223 49 49;            /* #DF3131 — urgency red */
    --aw-color-text-heading-rgb: 17 47 91;       /* navy */
    --aw-color-text-default-rgb: 51 65 85;       /* slate-700 */
    --aw-color-text-muted-rgb: 100 116 139;      /* slate-500 */
    --aw-color-bg-page-rgb: 250 249 246;         /* off-white #FAF9F6 */

    /* Legacy variables (some AstroWind components reference these directly) */
    --aw-color-primary: rgb(var(--aw-color-primary-rgb));
    --aw-color-secondary: rgb(var(--aw-color-secondary-rgb));
    --aw-color-accent: rgb(var(--aw-color-accent-rgb));
    --aw-color-text-heading: rgb(var(--aw-color-text-heading-rgb));
    --aw-color-text-default: rgb(var(--aw-color-text-default-rgb));
    --aw-color-text-muted: rgb(var(--aw-color-text-muted-rgb));
    --aw-color-text-page: rgb(var(--aw-color-text-default-rgb));
    --aw-color-bg-page: rgb(var(--aw-color-bg-page-rgb));
    --aw-color-bg-page-dark: rgb(var(--aw-color-secondary-rgb));

    ::selection {
      background-color: rgb(17 109 255 / 0.2);
    }
  }
</style>
