---
import { Image } from 'astro:assets';
import logo from '~/assets/logo.png';
import { SITE } from 'astrowind:config';
---

<span class="flex items-center gap-2.5 shrink-0" aria-label={SITE?.name}>
  <Image src={logo} alt="QuickFast Service Company" width={48} height={48} class="h-10 w-auto drop-shadow-md" loading="eager" />
  <span class="logo-text text-lg md:text-xl font-serif font-bold whitespace-nowrap transition-colors duration-500">
    QuickFast Service
  </span>
</span>
