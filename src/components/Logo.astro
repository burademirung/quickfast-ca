---
import { Image } from 'astro:assets';
import logo from '~/assets/logo.png';
import { SITE } from 'astrowind:config';
---

<span class="flex items-center gap-2.5 shrink-0" aria-label={SITE?.name}>
  <Image src={logo} alt="QuickFast Service Company" width={48} height={48} class="h-9 w-auto" loading="eager" />
  <span class="text-lg md:text-xl font-serif font-bold text-heading whitespace-nowrap">
    QuickFast Service
  </span>
</span>
