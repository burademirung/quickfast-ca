---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';

import { getHomePermalink, trimSlash } from '~/utils/permalinks';
import type { CallToAction } from '~/types';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = true,
  isFullWidth = false,
  position = 'center',
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  id={id}
  class:list={[
    isSticky ? 'sticky' : 'relative',
    'top-0 z-40 flex-none mx-auto w-full transition-all duration-500',
  ]}
  data-aw-sticky-header={isSticky}
  data-header-state="transparent"
>
  <div
    class:list={[
      'relative py-4 px-3 md:px-6 mx-auto w-full',
      { 'md:flex md:justify-between': position !== 'center' },
      { 'md:grid md:grid-cols-3 md:items-center': position === 'center' },
      { 'max-w-7xl': !isFullWidth },
    ]}
  >
    <div class:list={[{ 'mr-auto rtl:mr-0 rtl:ml-auto': position === 'right' }, 'flex justify-between']}>
      <a class="flex items-center" href={getHomePermalink()}>
        <Logo />
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu />
      </div>
    </div>

    <nav
      class="header-nav items-center w-full md:w-auto hidden md:flex md:mx-5 overflow-y-auto overflow-x-hidden md:overflow-y-visible md:overflow-x-auto md:justify-self-center"
      aria-label="Main navigation"
    >
      <ul
        class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-xl md:text-[0.95rem] tracking-[0.005rem] font-medium md:justify-center"
      >
        {links.map(({ text, href, links }) => (
          <li class={links?.length ? 'dropdown' : ''}>
            {links?.length ? (
              <>
                <button
                  type="button"
                  class="header-link px-4 py-3 flex items-center whitespace-nowrap rounded-lg transition-colors"
                >
                  {text}
                  <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-1 hidden md:inline" />
                </button>
                <ul class="dropdown-menu rounded-xl md:absolute pl-4 md:pl-0 md:hidden font-medium md:bg-white md:backdrop-blur-md md:min-w-[220px] md:shadow-2xl md:border md:border-secondary/10 md:py-2">
                  {links.map(({ text: text2, href: href2 }) => (
                    <li>
                      <a
                        class:list={[
                          'block py-2 px-5 text-default md:hover:bg-primary/5 md:hover:text-primary whitespace-no-wrap transition-colors first:rounded-t-xl last:rounded-b-xl',
                          { 'aw-link-active': href2 === currentPath },
                        ]}
                        href={href2}
                      >
                        {text2}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                class:list={[
                  'header-link px-4 py-3 flex items-center whitespace-nowrap rounded-lg transition-colors',
                  { 'aw-link-active': href === currentPath },
                ]}
                href={href}
              >
                {text}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div
      class:list={[
        { 'ml-auto rtl:ml-0 rtl:mr-auto': position === 'left' },
        'hidden md:self-center md:flex items-center md:mb-0 fixed w-full md:w-auto md:static justify-end left-0 rtl:left-auto rtl:right-0 bottom-0 p-3 md:p-0 md:justify-self-end',
      ]}
    >
      <div class="items-center flex justify-between w-full md:w-auto">
        {actions?.length ? (
          <span class="ml-4 rtl:ml-0 rtl:mr-4">
            {actions.map((btnProps) => (
              <Button {...btnProps} class="ml-2 py-2.5 px-6 font-semibold text-sm w-auto" />
            ))}
          </span>
        ) : (
          ''
        )}
      </div>
    </div>
  </div>
</header>

<script>
  // Adaptive header — transparent over dark hero, frosted-white when scrolled.
  // Switching is driven by data-header-state="transparent|solid".
  const header = document.getElementById('header');
  if (header) {
    const update = () => {
      const state = window.scrollY > 80 ? 'solid' : 'transparent';
      if (header.getAttribute('data-header-state') !== state) {
        header.setAttribute('data-header-state', state);
      }
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>

<style is:global>
  /* Transparent state — over the dark hero. White text, no background. */
  #header[data-header-state='transparent'] {
    background: transparent;
    box-shadow: none;
  }
  #header[data-header-state='transparent'] .header-link,
  #header[data-header-state='transparent'] .header-link:hover {
    color: rgba(255, 255, 255, 0.92);
  }
  #header[data-header-state='transparent'] .header-link:hover {
    background: rgba(255, 255, 255, 0.1);
  }
  #header[data-header-state='transparent'] .logo-text {
    color: white;
  }

  /* Solid state — over white page content. Dark text, frosted-white background. */
  #header[data-header-state='solid'] {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgb(var(--aw-color-secondary-rgb) / 0.08);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.04);
  }
  #header[data-header-state='solid'] .header-link {
    color: rgb(var(--aw-color-text-default-rgb));
  }
  #header[data-header-state='solid'] .header-link:hover {
    color: rgb(var(--aw-color-primary-rgb));
    background: rgb(var(--aw-color-primary-rgb) / 0.06);
  }
  #header[data-header-state='solid'] .logo-text {
    color: rgb(var(--aw-color-text-heading-rgb));
  }

  /* Mobile menu (when expanded, header always solid) */
  #header.expanded[data-header-state='transparent'] {
    background: white;
  }
  #header.expanded[data-header-state='transparent'] .header-link,
  #header.expanded[data-header-state='transparent'] .logo-text {
    color: rgb(var(--aw-color-text-default-rgb));
  }
</style>
