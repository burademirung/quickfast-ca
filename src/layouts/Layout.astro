---
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';
import WebVitals from '~/components/WebVitals.astro';
import RequestServiceDialog from '~/components/RequestServiceDialog.astro';
import CookieBanner from '~/components/CookieBanner.astro';

import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;

// Compute canonical URL — first option: from metadata.canonical override; fallback: current URL on the production site
const canonicalURL = metadata.canonical
  ? new URL(metadata.canonical, 'https://quickfast.ca').toString()
  : new URL(Astro.url.pathname, 'https://quickfast.ca').toString();

const robotsContent = (() => {
  const r = metadata.robots || {};
  const idx = r.index === false ? 'noindex' : 'index';
  const fol = r.follow === false ? 'nofollow' : 'follow';
  return `${idx}, ${fol}`;
})();
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />

    <!-- Canonical + favicons (correct attribute order — gotcha P) -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#112F5B" />
    <meta name="robots" content={robotsContent} />

    <CustomStyles />
    <Metadata {...metadata} />
    <SiteVerification />

    <ClientRouter fallback="swap" />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded"
      >Skip to main content</a
    >
    <noscript>
      <div class="bg-primary text-white px-4 py-3 text-center text-sm">
        JavaScript is disabled. To request service, call <a href="tel:+14166293213" class="font-semibold underline"
          >+1-416-629-3213</a
        >.
      </div>
    </noscript>

    <slot />

    <RequestServiceDialog />
    <CookieBanner />
    <WebVitals />

    <!-- Scroll entrance animation observer -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('[data-animate],[data-animate-fade]').forEach((el) => observer.observe(el));

        // Count-up animation for stats
        document.querySelectorAll('[data-count-up]').forEach((el) => {
          const target = parseInt(el.dataset.countUp || '0', 10);
          const suffix = el.textContent?.replace(/[0-9,]/g, '') || '';
          const ob = new IntersectionObserver(
            ([entry]) => {
              if (!entry.isIntersecting) return;
              ob.unobserve(el);
              let current = 0;
              const step = Math.max(1, Math.ceil(target / 40));
              const timer = setInterval(() => {
                current = Math.min(current + step, target);
                el.textContent = current + suffix;
                if (current >= target) clearInterval(timer);
              }, 30);
            },
            { threshold: 0.5 }
          );
          ob.observe(el);
        });

        // Back-to-top button visibility
        const btn = document.getElementById('back-to-top');
        if (btn) {
          window.addEventListener(
            'scroll',
            () => {
              const show = window.scrollY > 600;
              btn.classList.toggle('opacity-0', !show);
              btn.classList.toggle('translate-y-4', !show);
              btn.classList.toggle('opacity-100', show);
              btn.classList.toggle('translate-y-0', show);
            },
            { passive: true }
          );
          btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        }

        // Mobile sticky CTA — show after hero
        const mobileCta = document.getElementById('mobile-cta');
        const heroEl = document.querySelector('main section');
        if (mobileCta && heroEl) {
          const obs = new IntersectionObserver(
            ([e]) => {
              mobileCta.classList.toggle('opacity-0', e.isIntersecting);
              mobileCta.classList.toggle('translate-y-full', e.isIntersecting);
              mobileCta.classList.toggle('opacity-100', !e.isIntersecting);
              mobileCta.classList.toggle('translate-y-0', !e.isIntersecting);
            },
            { threshold: 0 }
          );
          obs.observe(heroEl);
        }
      });
    </script>

    <BasicScripts />
  </body>
</html>
