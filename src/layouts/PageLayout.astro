---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';

import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;
---

<Layout metadata={metadata}>
  <slot name="header">
    <Header {...headerData} isSticky showRssFeed={false} showToggleTheme={false} />
  </slot>
  <main id="main-content">
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>

  <!-- Mobile sticky CTA bar — visible after scrolling past hero -->
  <div
    id="mobile-cta"
    class="fixed bottom-0 left-0 right-0 z-40 md:hidden opacity-0 translate-y-full transition-all duration-300"
    style="padding-bottom: env(safe-area-inset-bottom);"
  >
    <div class="bg-secondary/95 backdrop-blur-sm border-t border-white/10 px-4 py-3 flex items-center justify-center gap-3">
      <a
        href="tel:+14166293213"
        class="flex-1 flex items-center justify-center gap-2 rounded-lg bg-primary py-3 text-white font-bold text-sm shadow-lg"
      >
        Call Now
      </a>
      <a
        href="/contact/"
        class="flex-1 flex items-center justify-center gap-2 rounded-lg bg-white/10 border border-white/20 py-3 text-white font-bold text-sm"
        data-open-request-dialog
      >
        Free Quote
      </a>
    </div>
  </div>

  <!-- Back-to-top button -->
  <button
    id="back-to-top"
    aria-label="Back to top"
    class="fixed bottom-20 right-4 z-40 w-12 h-12 rounded-full bg-secondary/80 text-white shadow-lg flex items-center justify-center opacity-0 translate-y-4 transition-all duration-300 hover:bg-secondary hover:scale-110 md:bottom-6"
  >
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"></path>
    </svg>
  </button>
</Layout>
