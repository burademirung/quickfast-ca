---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contact QuickFast Service Company | Mississauga',
  description:
    'Call +1-416-629-3213 or request service online. We respond within 1 business hour. Mississauga, Toronto, GTA — 24/7 emergency service available.',
};

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact QuickFast Service Company',
  url: 'https://quickfast.ca/contact/',
  mainEntity: { '@id': 'https://quickfast.ca/#business' },
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://quickfast.ca/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://quickfast.ca/contact/' },
  ],
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(contactSchema).replace(/</g, '\\u003c')} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb).replace(/</g, '\\u003c')} />
  </Fragment>

  <section class="relative min-h-[40vh] flex items-center overflow-hidden -mt-[72px]" style="background: linear-gradient(135deg, #112F5B 0%, #0a1f40 100%);">
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="relative z-10 mx-auto max-w-3xl px-6 text-center pt-32 pb-12">
      <p class="hero-fade text-xs font-bold uppercase tracking-[0.2em] text-blue-300 mb-3">Get in touch</p>
      <h1 class="hero-fade text-4xl sm:text-5xl font-serif font-bold text-white" style="animation-delay:120ms">
        Let's get the job done.
      </h1>
      <p class="hero-fade mt-4 text-lg text-gray-300" style="animation-delay:280ms">
        We respond within 1 business hour. Call, request service online, or stop by the Mississauga office.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-page">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 grid grid-cols-1 md:grid-cols-3 gap-5">
      <div class="card text-center" data-animate>
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
        </div>
        <h2 class="font-serif font-bold text-heading text-xl mb-2">Phone</h2>
        <a href="tel:+14166293213" class="text-primary font-semibold text-lg hover:underline" aria-label="Call QuickFast Service Company">+1 416-629-3213</a>
        <p class="text-muted text-sm mt-2">24/7 emergency line available</p>
      </div>

      <div class="card text-center" data-animate style="animation-delay:100ms">
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        </div>
        <h2 class="font-serif font-bold text-heading text-xl mb-2">Email</h2>
        <a href="mailto:info@quickfast.ca" class="text-primary font-semibold hover:underline" aria-label="Email QuickFast Service Company">info@quickfast.ca</a>
        <p class="text-muted text-sm mt-2">Replies within 1 business hour</p>
      </div>

      <div class="card text-center" data-animate style="animation-delay:200ms">
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        </div>
        <h2 class="font-serif font-bold text-heading text-xl mb-2">Visit</h2>
        <address class="text-default leading-relaxed">
          2390 Cawthra Road Unit #2<br />
          Mississauga, ON, L5A 2X1
        </address>
        <a href="https://www.google.com/maps/search/?api=1&query=2390+Cawthra+Road+Unit+%232%2C+Mississauga%2C+ON%2C+L5A+2X1" target="_blank" rel="noopener noreferrer" class="text-primary text-sm font-semibold mt-2 inline-block hover:underline">Open in Google Maps →</a>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-page bg-dots">
    <div class="max-w-3xl mx-auto px-4 text-center" data-animate>
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">Request Service</p>
      <h2 class="text-3xl sm:text-4xl font-serif font-bold text-heading mb-4">Submit a service request</h2>
      <p class="text-lg text-muted mb-8 max-w-xl mx-auto">
        Tell us what you need fixed, installed or renovated. We respond within 1 business hour with a free written quote.
      </p>
      <a href="/contact/" data-open-request-dialog class="btn-primary text-lg">Open Request Form</a>
    </div>
  </section>

  <section class="py-16 bg-secondary text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl sm:text-3xl font-serif font-bold mb-6" data-animate>Service area</h2>
      <p class="text-white/80 mb-6 max-w-2xl mx-auto" data-animate>
        We serve the entire Greater Toronto Area from our Mississauga office. Most service calls within 30 minutes of the office get same-day attention.
      </p>
      <ul class="flex flex-wrap items-center justify-center gap-3 text-sm" data-animate>
        <li class="px-4 py-1.5 rounded-full border border-white/15 bg-white/5">Mississauga</li>
        <li class="px-4 py-1.5 rounded-full border border-white/15 bg-white/5">Toronto</li>
        <li class="px-4 py-1.5 rounded-full border border-white/15 bg-white/5">Etobicoke</li>
        <li class="px-4 py-1.5 rounded-full border border-white/15 bg-white/5">Oakville</li>
        <li class="px-4 py-1.5 rounded-full border border-white/15 bg-white/5">Brampton</li>
        <li class="px-4 py-1.5 rounded-full border border-white/15 bg-white/5">Vaughan</li>
        <li class="px-4 py-1.5 rounded-full border border-white/15 bg-white/5">Markham</li>
        <li class="px-4 py-1.5 rounded-full border border-white/15 bg-white/5">Richmond Hill</li>
      </ul>
    </div>
  </section>
</Layout>
