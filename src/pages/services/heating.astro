---
import ServiceCategoryPage from '~/components/ServiceCategoryPage.astro';

const services = [
  { title: 'Furnace Installation', desc: 'High-efficiency gas furnace replacement with rebate paperwork.' },
  { title: 'Furnace Repair', desc: 'Same-day diagnosis and repair on most makes — ignition, blower, control board.' },
  { title: 'Boiler Installation', desc: 'Combi and standalone boilers for radiator, baseboard, and in-floor heat.' },
  { title: 'Boiler Repair', desc: 'Pump, ignition, expansion-tank, low-water cutoff repair.' },
  { title: 'Heat Pump Installation', desc: 'Cold-climate heat pumps eligible for the Greener Homes Grant + Ontario rebates.' },
  { title: 'Mini-Split Heat Installation', desc: 'Ductless heating for additions, basements, garages, and laneway suites.' },
  { title: 'Hydronic / Radiant Floor Heat', desc: 'In-floor radiant systems for new builds and renovations.' },
  { title: 'Thermostat & Zone Control', desc: 'Smart thermostat installation (Nest, Ecobee, Honeywell) and zoning.' },
  { title: 'Annual Furnace Tune-Up', desc: 'Pre-winter inspection — combustion analysis, filter, ignition, blower clean.' },
  { title: 'Emergency Heat Service', desc: '24/7 response when the furnace fails on the coldest night of the year.' },
];

const whyUs = [
  { title: 'TSSA-licensed', desc: 'All gas + heating work performed by TSSA-licensed technicians.' },
  { title: 'Brand-agnostic', desc: 'We install Lennox, Carrier, Trane, Goodman, Bosch, Mitsubishi — whatever fits.' },
  { title: 'Rebate paperwork included', desc: 'We file Greener Homes, IESO, and gas-utility rebate forms on your behalf.' },
  { title: '24/7 emergency response', desc: 'No-heat calls in winter get a 2-hour dispatch, 365 days a year.' },
];

const faqs = [
  { q: 'When should I replace my furnace?', a: 'Most gas furnaces last 15-20 years. If yours is 15+ years old, has rising repair costs, or your heating bills are climbing year-over-year, replace. We offer free energy-efficiency comparisons.' },
  { q: 'Are heat pumps worth it in Ontario?', a: 'Modern cold-climate heat pumps work down to -25°C and qualify for the federal Greener Homes Grant ($5,000) plus Ontario rebates. For most GTA homes, a heat pump + small backup gas furnace is the most efficient combo.' },
  { q: 'Do you install boilers?', a: 'Yes — combi-boilers (heat + domestic hot water in one unit) and standalone boilers for radiator, baseboard, and in-floor heat. TSSA-licensed installation with manufacturer warranty.' },
];

const longDescription =
  "QuickFast handles every part of your home's heating system — furnaces, boilers, heat pumps, mini-splits, in-floor radiant, and smart thermostats. <strong>TSSA-licensed installation</strong>, brand-agnostic procurement, and full rebate paperwork on every install. Same-day repair on most failures. 24/7 emergency dispatch when the heat goes out.";
---

<ServiceCategoryPage
  slug="heating"
  title="Heating"
  kicker="Service Category"
  intro="Furnaces, boilers, heat pumps and mini-splits — installation, repair and 24/7 emergency service across Mississauga and the GTA."
  longDescription={longDescription}
  services={services}
  metaDescription="Heating in Mississauga & GTA — furnace, boiler, heat pump and mini-split installation, repair, tune-ups. TSSA-licensed, 24/7 emergency, rebate-eligible."
  whyUs={whyUs}
  faqs={faqs}
/>
