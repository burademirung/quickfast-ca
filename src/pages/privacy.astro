---
import Layout from '~/layouts/PageLayout.astro';

const updated = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const metadata = {
  title: 'Privacy Policy',
  description:
    'How QuickFast Service Company collects, uses and protects your personal information. Last updated ' + updated + '.',
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://quickfast.ca/' },
    { '@type': 'ListItem', position: 2, name: 'Privacy', item: 'https://quickfast.ca/privacy/' },
  ],
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb).replace(/</g, '\\u003c')} />
  </Fragment>

  <section class="bg-secondary text-white py-16 pt-32">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="text-4xl sm:text-5xl font-serif font-bold">Privacy Policy</h1>
      <p class="text-white/70 mt-3">Last updated: {updated}</p>
    </div>
  </section>

  <article class="py-16 lg:py-20 bg-page">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 prose prose-lg max-w-none">
      <h2 class="text-2xl font-serif font-bold text-heading mt-0 mb-3">What we collect</h2>
      <p>QuickFast Service Company (we, us, our) collects only what we need to respond to your service request and complete the work:</p>
      <ul>
        <li><strong>Contact form submissions</strong> — name, phone, email, service category, and the message you send us.</li>
        <li><strong>Service records</strong> — address, equipment serviced, dates and invoices for work we performed.</li>
        <li><strong>Anonymous usage analytics</strong> — Cloudflare Web Analytics tracks page views and Core Web Vitals without setting cookies or fingerprinting visitors.</li>
      </ul>

      <h2 class="text-2xl font-serif font-bold text-heading mt-10 mb-3">How we use it</h2>
      <p>We use your information to:</p>
      <ul>
        <li>Respond to service requests and provide quotes.</li>
        <li>Schedule and complete work at your property.</li>
        <li>Send invoices and warranty / receipt records.</li>
        <li>Improve our services based on aggregated, anonymous analytics.</li>
      </ul>
      <p>We do <strong>not</strong> sell, rent or trade your personal information to third parties.</p>

      <h2 class="text-2xl font-serif font-bold text-heading mt-10 mb-3">Retention</h2>
      <p>Service-request submissions are retained for up to 90 days in our edge KV store before automatic purge. Service records (invoices, warranty paperwork) are retained for 7 years per Canadian tax and warranty requirements. You can request earlier deletion at any time.</p>

      <h2 class="text-2xl font-serif font-bold text-heading mt-10 mb-3">Third-party services</h2>
      <ul>
        <li><strong>Cloudflare Pages</strong> — hosting and DDoS protection. Cloudflare's privacy policy: <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">cloudflare.com/privacypolicy</a>.</li>
        <li><strong>Resend</strong> (transactional email, when configured) — used to email service-request notifications to our team. <a href="https://resend.com/legal/privacy-policy" target="_blank" rel="noopener noreferrer">Resend privacy policy</a>.</li>
        <li><strong>Cloudflare Turnstile</strong> (when enabled on the contact form) — privacy-preserving captcha. No tracking cookies set.</li>
      </ul>

      <h2 class="text-2xl font-serif font-bold text-heading mt-10 mb-3">Cookies</h2>
      <p>We use a single first-party preference key in browser localStorage to remember your cookie banner choice. We do not use third-party advertising or tracking cookies.</p>

      <h2 class="text-2xl font-serif font-bold text-heading mt-10 mb-3">Your rights</h2>
      <p>Under PIPEDA and CASL, you can request a copy of any personal information we hold about you, request correction or deletion, or withdraw consent at any time. Email <a href="mailto:info@quickfast.ca">info@quickfast.ca</a> or call <a href="tel:+14166293213">+1-416-629-3213</a>.</p>

      <h2 class="text-2xl font-serif font-bold text-heading mt-10 mb-3">Changes</h2>
      <p>We may update this policy as our services or legal obligations change. The "Last updated" date at the top reflects the most recent revision. Material changes will be highlighted on the home page.</p>

      <h2 class="text-2xl font-serif font-bold text-heading mt-10 mb-3">Contact</h2>
      <p>Privacy questions: <a href="mailto:info@quickfast.ca">info@quickfast.ca</a> · <a href="tel:+14166293213">+1-416-629-3213</a><br />
      QuickFast Service Company, 2390 Cawthra Road Unit #2, Mississauga, ON, L5A 2X1.</p>
    </div>
  </article>
</Layout>
