---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About QuickFast Service Company',
  description:
    "15+ years of HVAC, plumbing, electrical and renovation expertise serving Mississauga and the GTA. Family-owned, ESA-certified, TSSA-licensed and fully insured.",
};

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About QuickFast Service Company',
  url: 'https://quickfast.ca/about/',
  mainEntity: { '@id': 'https://quickfast.ca/#business' },
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://quickfast.ca/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: 'https://quickfast.ca/about/' },
  ],
};

const stats = [
  { number: '15', suffix: '+', label: 'Years in Business' },
  { number: '500', suffix: '+', label: 'Properties Serviced' },
  { number: '1', suffix: 'hr', label: 'Average Response' },
  { number: '100', suffix: '%', label: 'Workmanship Guaranteed' },
];

const principles = [
  {
    title: 'Show up on time',
    desc: 'When we book a window, we keep it. If the technician will be more than 15 minutes late, you get a call — not a no-show.',
  },
  {
    title: 'Quote it once',
    desc: 'You see the price before the work starts. The number on the invoice matches the number on the quote — no surprise add-ons.',
  },
  {
    title: 'Fix the cause, not the symptom',
    desc: "If the same drain keeps clogging, we don't sell you another snake-out. We diagnose root intrusion, scale buildup or a venting issue, and solve it for good.",
  },
  {
    title: 'Stand behind the work',
    desc: 'Every installation comes with a written workmanship guarantee. If something goes wrong inside the warranty window, we come back at no charge.',
  },
];
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(aboutSchema).replace(/</g, '\\u003c')} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb).replace(/</g, '\\u003c')} />
  </Fragment>

  <section class="relative min-h-[55vh] flex items-center overflow-hidden" style="background: linear-gradient(135deg, #112F5B 0%, #0a1f40 100%);">
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-[10%] right-[5%] w-[400px] h-[400px] rounded-full opacity-[0.18] blur-[100px]" style="background: radial-gradient(circle, #116DFF, transparent 70%); animation: drift 22s ease-in-out infinite alternate;"></div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center pt-32 pb-16">
      <p class="hero-fade text-xs font-bold uppercase tracking-[0.2em] text-blue-300 mb-3">About Us</p>
      <h1 class="hero-fade text-4xl sm:text-5xl lg:text-6xl font-serif font-bold text-white leading-tight" style="animation-delay:120ms">
        15 years of doing the job
        <span class="block" style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; background-image: linear-gradient(135deg, #60A5FA, #FBBF24);">the way it should be done.</span>
      </h1>
      <p class="hero-fade mt-6 text-lg text-gray-200 max-w-2xl mx-auto" style="animation-delay:280ms">
        Family-owned. Mississauga-based. Trusted by homeowners, condo boards, and property managers across the GTA.
      </p>
    </div>
  </section>

  <section class="py-20 lg:py-24 bg-page">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div data-animate class="prose prose-lg max-w-none">
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-heading mb-6">Our story</h2>
        <p class="text-lg text-default leading-relaxed mb-6">
          QuickFast Service Company started in Mississauga in 2010 with a simple idea: most homeowners get bounced between three or four different contractors for what should be one straightforward job. A leaking water heater becomes a plumber, an electrician, and a drywall repair — three trips, three invoices, three different stories about who broke what.
        </p>
        <p class="text-lg text-default leading-relaxed mb-6">
          We built QuickFast as the alternative. Every trade — HVAC, plumbing, electrical, and renovations — handled by certified technicians on our own team. One call. One quote. One company that owns the result from start to finish.
        </p>
        <p class="text-lg text-default leading-relaxed mb-6">
          Fifteen years later, we maintain over 500 properties across Mississauga, Toronto, and the GTA — single-family homes, condos, and commercial buildings. We're ESA-certified for electrical work, TSSA-licensed for gas and HVAC, fully insured, and our technicians carry WSIB coverage. Every installation comes with a written workmanship guarantee.
        </p>
        <p class="text-lg text-default leading-relaxed">
          We're still family-owned. The phone still gets answered by a person, not a chatbot. And our commitment hasn't changed: show up on time, quote it once, and stand behind the work.
        </p>
      </div>
    </div>
  </section>

  <section class="relative py-16 sm:py-20 overflow-hidden" style="background: linear-gradient(135deg, #116DFF 0%, #112F5B 100%);">
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="relative z-10 mx-auto max-w-5xl px-4 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {stats.map((s, i) => (
        <div data-animate style={`animation-delay: ${i * 120}ms`}>
          <p class="text-4xl md:text-5xl font-bold text-white" data-count-up={s.number}>{s.number}{s.suffix}</p>
          <p class="mt-2 text-sm text-white/80 uppercase tracking-wider">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-20 lg:py-24 bg-page">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14" data-animate>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">Our Principles</p>
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-heading">How we run every job</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {principles.map((p, i) => (
          <div class="card" data-animate style={`animation-delay: ${i * 100}ms`}>
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary font-bold">
                {i + 1}
              </div>
              <div>
                <h3 class="text-xl font-serif font-bold text-heading mb-2">{p.title}</h3>
                <p class="text-muted leading-relaxed">{p.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-secondary text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl sm:text-3xl font-serif font-bold mb-8" data-animate>Credentials & Memberships</h2>
      <ul class="flex flex-wrap items-center justify-center gap-3 text-sm" data-animate>
        <li class="px-4 py-2 rounded-full border border-white/15 bg-white/5">ESA Certified Electrical Contractor</li>
        <li class="px-4 py-2 rounded-full border border-white/15 bg-white/5">TSSA Licensed Gas / HVAC</li>
        <li class="px-4 py-2 rounded-full border border-white/15 bg-white/5">WSIB Coverage</li>
        <li class="px-4 py-2 rounded-full border border-white/15 bg-white/5">Fully Insured</li>
        <li class="px-4 py-2 rounded-full border border-white/15 bg-white/5">Workmanship Guarantee</li>
      </ul>
    </div>
  </section>

  <section class="py-20 bg-page">
    <div class="max-w-3xl mx-auto px-4 text-center" data-animate>
      <h2 class="text-3xl sm:text-4xl font-serif font-bold text-heading mb-4">Work with us</h2>
      <p class="text-lg text-muted mb-8">Get a free written quote within one business hour.</p>
      <a href="/contact/" data-open-request-dialog class="btn-primary">Request Service</a>
    </div>
  </section>
</Layout>
