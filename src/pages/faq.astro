---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Frequently Asked Questions',
  description:
    "Answers to the most common questions homeowners and property managers ask QuickFast about HVAC, plumbing, electrical, renovations and emergency service.",
};

const faqs = [
  {
    cat: 'General',
    items: [
      {
        q: 'What areas does QuickFast Service Company serve?',
        a: 'We serve Mississauga, Toronto, and the entire Greater Toronto Area (GTA), including Etobicoke, Oakville, Brampton, Vaughan, Markham and Richmond Hill. Our central office is at 2390 Cawthra Road in Mississauga.',
      },
      {
        q: 'Are you licensed and insured?',
        a: 'Yes. We are ESA-certified for electrical contracting work, TSSA-licensed for gas and HVAC work, and fully insured. Our technicians carry WSIB coverage. All installation work comes with a written workmanship guarantee.',
      },
      {
        q: 'How fast can you respond to a service call?',
        a: 'For most service calls in the Mississauga / Toronto area, we respond within 1 hour during business hours and within 2-4 hours for emergencies after-hours. Maintenance plan members get priority scheduling.',
      },
      {
        q: 'Do you offer 24/7 emergency service?',
        a: 'Yes. We have on-call technicians for emergency plumbing, HVAC, and electrical issues 24 hours a day, 7 days a week, including weekends and holidays. Call +1-416-629-3213 for after-hours service.',
      },
    ],
  },
  {
    cat: 'Pricing & quotes',
    items: [
      {
        q: 'Do you provide free estimates?',
        a: 'Yes — installation and renovation quotes are always free and written. For repair calls, a $95 service-call fee covers diagnosis. The fee is waived if you proceed with the recommended work.',
      },
      {
        q: "What's included in a written quote?",
        a: 'Every quote itemizes equipment, labour, permits, disposal fees and applicable taxes. Quotes are valid for 30 days. We do not require deposits to deliver a quote.',
      },
      {
        q: 'Do you accept credit cards?',
        a: 'Yes — we accept Visa, Mastercard, AmEx, e-transfer, cheque and cash. Financing is available on installations through our partner Snap Financial.',
      },
    ],
  },
  {
    cat: 'HVAC',
    items: [
      {
        q: 'When should I replace my furnace?',
        a: 'Most gas furnaces last 15-20 years. If yours is 15+ years old, has rising repair costs, or your heating bills are climbing year-over-year, it may be time to replace. We offer free energy-efficiency comparisons.',
      },
      {
        q: 'Are heat pumps worth it in Ontario?',
        a: 'Modern cold-climate heat pumps work efficiently down to -25°C and qualify for the federal Greener Homes Grant + Ontario rebates. For most GTA homes, a heat pump + small backup gas furnace is the most efficient combo.',
      },
      {
        q: 'How often should I service my AC?',
        a: 'Annually, before peak summer. A spring tune-up extends equipment life, prevents breakdowns during heat waves, and keeps your warranty valid. Our maintenance plan covers it.',
      },
    ],
  },
  {
    cat: 'Plumbing',
    items: [
      {
        q: 'My drain keeps backing up. Snaking it never lasts. Why?',
        a: 'Repeat clogs in the same drain usually mean tree-root intrusion, a belly in the pipe, or scale buildup. We do a sewer-camera inspection ($249) to identify the actual cause, then quote a permanent fix instead of another snake-out.',
      },
      {
        q: 'Tank or tankless water heater?',
        a: "Tankless is more efficient and lasts ~20 years vs. 8-12 for a tank. It costs 1.5-2× upfront. For most 3-4 person households the payback is 7-10 years. We'll quote both with operating-cost comparisons.",
      },
    ],
  },
  {
    cat: 'Electrical',
    items: [
      {
        q: 'Do I need a 200-amp panel upgrade?',
        a: "If you're adding a heat pump, EV charger, hot tub, or a major addition — usually yes. Most 1960s-1980s GTA homes have 100A service which is at capacity once you add modern loads. ESA inspection is included in our panel-upgrade quote.",
      },
      {
        q: 'How much is an EV charger install?',
        a: 'Typical Level-2 EV charger install on an existing 200A panel runs $1,200-$1,800 including the charger, conduit, and ESA inspection. Add $500-$1,500 if a panel upgrade is required.',
      },
    ],
  },
];

const allFaqs = faqs.flatMap((c) => c.items);
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allFaqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://quickfast.ca/' },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: 'https://quickfast.ca/faq/' },
  ],
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema).replace(/</g, '\\u003c')} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb).replace(/</g, '\\u003c')} />
  </Fragment>

  <section class="relative min-h-[40vh] flex items-center overflow-hidden" style="background: linear-gradient(135deg, #112F5B 0%, #0a1f40 100%);">
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-6 text-center pt-32 pb-12">
      <p class="hero-fade text-xs font-bold uppercase tracking-[0.2em] text-blue-300 mb-3">FAQ</p>
      <h1 class="hero-fade text-4xl sm:text-5xl font-serif font-bold text-white" style="animation-delay:120ms">
        Questions homeowners ask us
      </h1>
      <p class="hero-fade mt-4 text-lg text-gray-300" style="animation-delay:280ms">
        Real answers — about scheduling, pricing, what's covered, and what isn't.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-page">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      {faqs.map((cat, ci) => (
        <div class={ci > 0 ? 'mt-14' : ''}>
          <h2 class="text-2xl font-serif font-bold text-heading mb-5" data-animate>{cat.cat}</h2>
          <div class="space-y-3">
            {cat.items.map((f, i) => (
              <details class="group rounded-xl border border-secondary/10 bg-white p-5 transition-all hover:border-primary/30 hover:shadow-md" data-animate style={`animation-delay: ${i * 60}ms`}>
                <summary class="cursor-pointer list-none flex items-start justify-between gap-4">
                  <h3 class="text-base sm:text-lg font-semibold text-heading">{f.q}</h3>
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-1 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <p class="mt-3 text-default leading-relaxed">{f.a}</p>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="py-16 bg-secondary text-white text-center">
    <div class="max-w-2xl mx-auto px-4" data-animate>
      <h2 class="text-2xl sm:text-3xl font-serif font-bold mb-4">Still have questions?</h2>
      <p class="text-white/80 mb-6">Call us — a real person picks up.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="tel:+14166293213" class="btn-primary">+1 416-629-3213</a>
        <a href="/contact/" data-open-request-dialog class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-9 py-4 text-base font-semibold text-white hover:bg-white/10 transition">Request Service</a>
      </div>
    </div>
  </section>
</Layout>
