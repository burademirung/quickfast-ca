---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '~/assets/migrated/52afced9-11062b_26bec688bbde40818a6a17c9e91ba9c0~mv2.jpg';
import proudlyCanadian from '~/assets/proudly-canadian.png';

const metadata = {
  title:
    'QuickFast Service Company — HVAC, Plumbing, Electrical & Renovations | Mississauga',
  description:
    "Mississauga's HVAC, plumbing, electrical, duct cleaning + renovation team. 15+ years, ESA-certified, TSSA-licensed, 24/7 emergency. One company.",
  ignoreTitleTemplate: true,
};

const services = [
  {
    title: 'HVAC & Heating',
    description:
      'Furnace, boiler and heat-pump installation, AC repair, mini-split systems, ERV/HRV — TSSA-licensed.',
    href: '/services/hvac/',
    iconPath: 'M12 2c.5 3 2.5 4.5 4 6 1.5 1.5 2 3.5 2 5a6 6 0 11-12 0c0-2 1-3.5 2-5 1-1.5 1.5-3 1-4.5C10 4 11 3 12 2z',
  },
  {
    title: 'Plumbing',
    description:
      '24/7 emergency plumbing, hot water tanks, drain cleaning, sewer line repair, sump pumps and waterproofing.',
    href: '/services/plumbing/',
    iconPath: 'M12 2.5l5 7.5a6 6 0 11-10 0L12 2.5z',
  },
  {
    title: 'Electrical',
    description:
      'ESA-certified panel upgrades, EV charger installs, generators, lighting, residential inspections, red-tag removal.',
    href: '/services/electrical/',
    iconPath: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Medical-Grade Duct Cleaning',
    description:
      'Hospital-grade vacuums and HEPA-filtered process. Improves indoor air quality and HVAC efficiency.',
    href: '/services/duct-cleaning/',
    iconPath: 'M3 12h13a3 3 0 100-6M3 18h17a3 3 0 100-6',
  },
  {
    title: 'Renovations',
    description:
      'Bathroom, basement, condo and laneway-suite renovations. Full project management from permit to finish.',
    href: '/services/renovations/',
    iconPath:
      'M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z',
  },
  {
    title: 'Commercial & Property Mgmt',
    description:
      'Multi-unit residential, condo HVAC fleet replacement, commercial inspections and ongoing property maintenance.',
    href: '/services/commercial/',
    iconPath: 'M3 21V8a2 2 0 012-2h14a2 2 0 012 2v13M3 21h18M9 21V13M15 21V13M9 9h.01M15 9h.01M9 5h.01M15 5h.01',
  },
];

const trustBadges = [
  'Licensed & Insured',
  'ESA Certified',
  'TSSA Licensed',
  '24/7 Emergency',
  '15+ Years Experience',
];

const whyUs = [
  {
    title: '1-hour response',
    desc: 'During business hours we arrive within an hour for most service calls in the Mississauga–Toronto corridor.',
  },
  {
    title: 'Fixed-price quotes',
    desc: 'Free written estimates on installations and renovations. No surprise charges on the invoice.',
  },
  {
    title: 'Workmanship guarantee',
    desc: 'Every installation is backed by our written workmanship guarantee — we come back if anything goes wrong.',
  },
  {
    title: 'One company, all trades',
    desc: 'HVAC, plumbing, electrical and renovations under one roof — no chasing four contractors for one project.',
  },
];

const faqs = [
  {
    q: 'What areas does QuickFast Service Company serve?',
    a: 'We serve Mississauga, Toronto, and the entire Greater Toronto Area (GTA). Our central office is on Cawthra Road in Mississauga and our technicians cover Etobicoke, Oakville, Brampton, Vaughan, Markham and Richmond Hill.',
  },
  {
    q: 'Are you licensed and insured?',
    a: 'Yes — ESA-certified for electrical work, TSSA-licensed for gas/HVAC, and fully insured with WSIB coverage. All installation work comes with a written workmanship guarantee.',
  },
  {
    q: 'Do you offer 24/7 emergency service?',
    a: 'Yes. We have on-call technicians for emergency plumbing, HVAC, and electrical issues 24 hours a day, 7 days a week, including holidays. Call +1-416-629-3213 for after-hours service.',
  },
];

const homeSchemaBundle = [
  {
    '@context': 'https://schema.org',
    '@type': 'HomeAndConstructionBusiness',
    '@id': 'https://quickfast.ca/#business',
    name: 'QuickFast Service Company',
    url: 'https://quickfast.ca/',
    telephone: '+1-416-629-3213',
    email: 'info@quickfast.ca',
    description:
      'HVAC, plumbing, electrical, duct cleaning and renovations for residential, commercial, and condo properties across Mississauga and the GTA.',
    image: 'https://quickfast.ca/og-image.png',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '2390 Cawthra Road Unit #2',
      addressLocality: 'Mississauga',
      addressRegion: 'ON',
      postalCode: 'L5A 2X1',
      addressCountry: 'CA',
    },
    openingHoursSpecification: [
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '08:00',
        closes: '18:00',
      },
      { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Saturday', opens: '09:00', closes: '15:00' },
    ],
    priceRange: '$$',
    areaServed: ['Mississauga', 'Toronto', 'Etobicoke', 'Oakville', 'Brampton', 'Vaughan', 'Markham'],
    sameAs: [],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': 'https://quickfast.ca/#org',
    name: 'QuickFast Service Company',
    url: 'https://quickfast.ca/',
    logo: { '@type': 'ImageObject', url: 'https://quickfast.ca/apple-touch-icon.png' },
    contactPoint: [
      {
        '@type': 'ContactPoint',
        telephone: '+1-416-629-3213',
        contactType: 'customer service',
        areaServed: ['Mississauga', 'ON', 'CA'],
        availableLanguage: ['English'],
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': 'https://quickfast.ca/#author',
    name: 'QuickFast Service Company',
    jobTitle: 'Property Service Specialists',
    worksFor: { '@id': 'https://quickfast.ca/#org' },
    knowsAbout: ['HVAC', 'plumbing', 'electrical wiring', 'duct cleaning', 'home renovations', 'property management'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': 'https://quickfast.ca/#website',
    url: 'https://quickfast.ca/',
    name: 'QuickFast Service Company',
    publisher: { '@id': 'https://quickfast.ca/#org' },
    inLanguage: 'en-CA',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://quickfast.ca/' }],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    speakable: { '@type': 'SpeakableSpecification', cssSelector: ['h1', 'h2', '.lead'] },
  },
];

// Eagerly import all migrated images so they are referenced in dist/ for image-parity gate.
const allMigrated = Object.values(import.meta.glob('~/assets/migrated/*.{png,jpg,jpeg,webp,gif,svg}', { eager: true, import: 'default' })) as any[];
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    {homeSchemaBundle.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s).replace(/</g, '\\u003c')} />)}
  </Fragment>

  {/* HERO — immersive, real photo with gradient overlay */}
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">
    <Image
      src={heroImage}
      alt="QuickFast technician at a customer's home in Mississauga"
      width={1920}
      height={1080}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(17,47,91,0.92) 0%, rgba(17,47,91,0.78) 50%, rgba(17,109,255,0.55) 100%);"></div>
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] rounded-full opacity-[0.18] blur-[100px]" style="background: radial-gradient(circle, #116DFF, transparent 70%); animation: drift 20s ease-in-out infinite alternate;"></div>
    <div class="absolute bottom-[5%] left-[-5%] w-[400px] h-[400px] rounded-full opacity-[0.15] blur-[80px]" style="background: radial-gradient(circle, #DF3131, transparent 70%); animation: drift 25s ease-in-out infinite alternate-reverse;"></div>

    <div class="relative z-10 mx-auto max-w-5xl px-6 text-center pt-32 pb-20">
      <div class="hero-fade inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-md px-5 py-2.5 mb-10" style="animation-delay:0ms">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"></span>
        </span>
        <span class="text-[13px] font-medium text-gray-200 tracking-wide">Available 24/7 — including weekends + holidays</span>
      </div>

      <h1 class="hero-fade" style="animation-delay:120ms">
        <span class="block text-[clamp(2.5rem,6vw,5rem)] font-bold leading-[1.05] tracking-[-0.025em] text-white" style="font-family: Georgia, serif;">
          24/7 Property Services
          <br />
          <span style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; background-image: linear-gradient(135deg, #60A5FA 0%, #FBBF24 50%, #60A5FA 100%); background-size: 200% auto; animation: shimmer 4s linear infinite;">
            You Can Trust
          </span>
        </span>
      </h1>

      <p class="hero-fade lead mx-auto mt-6 max-w-2xl text-[1.15rem] leading-relaxed text-gray-200" style="animation-delay:280ms">
        Mississauga's full-service HVAC, plumbing, electrical, duct-cleaning and renovation team — serving homes, condos and commercial buildings for over <span class="text-white font-semibold">15 years</span>.
      </p>

      <div class="hero-fade mt-10 flex flex-col sm:flex-row items-center justify-center gap-4" style="animation-delay:440ms">
        <a
          href="/contact/"
          data-open-request-dialog
          class="group relative inline-flex items-center gap-2 rounded-xl px-9 py-4 text-[1.05rem] font-bold text-white overflow-hidden shadow-[0_4px_30px_rgba(17,109,255,0.4)] hover:shadow-[0_8px_50px_rgba(17,109,255,0.55)] transition-all duration-500 hover:scale-[1.03] active:scale-[0.97]"
        >
          <span class="absolute inset-0 bg-gradient-to-r from-primary to-blue-400 rounded-xl"></span>
          <span class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/20 to-transparent skew-x-[-20deg]"></span>
          <span class="relative z-10">Request Service</span>
          <svg class="relative z-10 w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a
          href="tel:+14166293213"
          class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 backdrop-blur-sm px-9 py-4 text-[1.05rem] font-semibold text-white hover:bg-white/10 hover:border-white/25 transition-all duration-300"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          +1 416-629-3213
        </a>
      </div>

      <div class="hero-fade mt-14 mx-auto max-w-2xl rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-6" style="animation-delay:600ms">
        <div class="grid grid-cols-3 divide-x divide-white/10">
          <div class="text-center px-3">
            <div class="text-3xl sm:text-4xl font-bold text-white tracking-tight" data-count-up="15">15+</div>
            <div class="text-[10px] sm:text-[11px] text-gray-300 mt-1 uppercase tracking-widest">Years Serving</div>
          </div>
          <div class="text-center px-3">
            <div class="text-3xl sm:text-4xl font-bold text-white tracking-tight" data-count-up="500">500+</div>
            <div class="text-[10px] sm:text-[11px] text-gray-300 mt-1 uppercase tracking-widest">Properties Cared For</div>
          </div>
          <div class="text-center px-3">
            <div class="text-3xl sm:text-4xl font-bold text-white tracking-tight">24/7</div>
            <div class="text-[10px] sm:text-[11px] text-gray-300 mt-1 uppercase tracking-widest">Emergency Service</div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-page to-transparent pointer-events-none"></div>
  </section>

  {/* TRUST BADGE BAR + Proudly Canadian */}
  <section class="bg-page border-y border-secondary/5 py-5">
    <div class="max-w-6xl mx-auto px-4 flex flex-wrap items-center justify-center gap-x-6 gap-y-3 text-xs sm:text-sm font-medium text-muted">
      {trustBadges.map((b) => (
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          {b}
        </span>
      ))}
      <span class="flex items-center gap-1.5">
        <Image src={proudlyCanadian} alt="Proudly Canadian" width={120} height={45} class="h-7 w-auto" loading="lazy" />
      </span>
    </div>
  </section>

  {/* LIMITED OFFER — Rebates & Financing callout (extracted from old site) */}
  <section class="relative py-20 lg:py-24 overflow-hidden bg-page bg-dots">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-10 items-center">
      <div data-animate>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent/10 text-accent text-xs font-bold uppercase tracking-widest mb-5">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
          </span>
          Limited Offer
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-bold text-heading leading-tight mb-5">
          Don't miss out — up to
          <span style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; background-image: linear-gradient(135deg, #DF3131, #116DFF);"> $10,500 </span>
          in rebates + financing
        </h2>
        <p class="text-lg text-default leading-relaxed mb-5">
          Upgrading your home's equipment doesn't have to be expensive. Federal Greener Homes Grant ($5,000), IESO save-on-energy rebates, manufacturer rebates, and 0% promotional financing through Snap stack to lower your out-of-pocket cost dramatically.
        </p>
        <p class="text-default leading-relaxed mb-7">
          QuickFast helps homeowners and property managers install qualifying energy-efficient systems — heat pumps, high-efficiency furnaces, tankless water heaters, smart thermostats — and we file every rebate form on your behalf.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/contact/" data-open-request-dialog class="btn-primary">Check my rebate eligibility</a>
          <a href="/pricing/" class="btn-secondary">See plans & pricing</a>
        </div>
      </div>

      {/* Rebate-stack visual — sums to $10,500 max */}
      <div class="relative" data-animate style="animation-delay:140ms">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/20 via-accent/10 to-transparent blur-3xl"></div>
        <div class="relative rounded-3xl bg-secondary text-white p-8 sm:p-10 shadow-2xl border border-white/10">
          <div class="flex items-center justify-between mb-6">
            <p class="text-xs font-bold uppercase tracking-widest text-blue-300">Rebate Stack</p>
            <span class="text-xs text-white/60">Maximum potential</span>
          </div>
          <ul class="space-y-4 mb-8">
            <li class="flex items-baseline justify-between gap-4 pb-3 border-b border-white/10">
              <div>
                <p class="font-semibold">Greener Homes Grant</p>
                <p class="text-xs text-white/60">Federal · heat pumps + insulation</p>
              </div>
              <span class="text-xl font-serif font-bold text-blue-300">$5,000</span>
            </li>
            <li class="flex items-baseline justify-between gap-4 pb-3 border-b border-white/10">
              <div>
                <p class="font-semibold">IESO Save-on-Energy</p>
                <p class="text-xs text-white/60">Provincial · HVAC + insulation</p>
              </div>
              <span class="text-xl font-serif font-bold text-blue-300">$3,000</span>
            </li>
            <li class="flex items-baseline justify-between gap-4 pb-3 border-b border-white/10">
              <div>
                <p class="font-semibold">Manufacturer Rebates</p>
                <p class="text-xs text-white/60">Lennox / Carrier / Bosch / Mitsubishi</p>
              </div>
              <span class="text-xl font-serif font-bold text-blue-300">$1,500</span>
            </li>
            <li class="flex items-baseline justify-between gap-4 pb-3 border-b border-white/10">
              <div>
                <p class="font-semibold">Gas-Utility Rebates</p>
                <p class="text-xs text-white/60">Enbridge HER+ furnace + WH</p>
              </div>
              <span class="text-xl font-serif font-bold text-blue-300">$1,000</span>
            </li>
          </ul>
          <div class="flex items-baseline justify-between gap-4 pt-2">
            <span class="text-sm font-semibold uppercase tracking-widest text-white/80">Total potential</span>
            <span class="text-3xl sm:text-4xl font-serif font-bold" style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; background-image: linear-gradient(135deg, #FBBF24, #60A5FA);">$10,500</span>
          </div>
          <p class="mt-5 text-xs text-white/50 leading-relaxed">
            Plus 0% promo financing through Snap (OAC). Eligibility depends on equipment type, install date, and program availability — we confirm before quoting.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* SERVICES — bento grid */}
  <section class="py-20 lg:py-24 bg-page bg-dots">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14" data-animate>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">Our Services</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-bold text-heading max-w-3xl mx-auto leading-tight">
          One company.
          <span class="text-primary block">Every property service you need.</span>
        </h2>
        <p class="mt-5 text-muted max-w-2xl mx-auto text-lg">
          Stop calling four different contractors. From a clogged drain to a full bathroom rebuild, our in-house technicians handle every trade — under one roof, with one accountable team.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((s, i) => (
          <a href={s.href} class="card group relative overflow-hidden" data-animate style={`animation-delay: ${i * 80}ms`}>
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-5 group-hover:scale-110 group-hover:bg-primary group-hover:text-white transition-all duration-300">
              <svg class="w-6 h-6 text-primary group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={s.iconPath}></path>
              </svg>
            </div>
            <h3 class="text-xl font-serif font-bold text-heading mb-2 group-hover:text-primary transition-colors">{s.title}</h3>
            <p class="text-muted text-sm leading-relaxed">{s.description}</p>
            <div class="mt-4 inline-flex items-center gap-1 text-primary font-semibold text-sm">
              Learn more
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* WHY US — alternating dark band */}
  <section class="relative py-20 lg:py-28 overflow-hidden" style="background: linear-gradient(135deg, #112F5B 0%, #0a1f40 100%);">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-[-15%] right-[-5%] w-[500px] h-[500px] rounded-full opacity-[0.12] blur-[100px]" style="background: radial-gradient(circle, #116DFF, transparent 70%);"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14" data-animate>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-blue-300 mb-3">Why Choose QuickFast</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-bold text-white max-w-3xl mx-auto leading-tight">
          The reasons our clients
          <span style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; background-image: linear-gradient(135deg, #60A5FA, #FBBF24);">stay with us for years</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        {whyUs.map((w, i) => (
          <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6 hover:bg-white/10 hover:border-white/20 transition-all duration-300" data-animate style={`animation-delay: ${i * 100}ms`}>
            <div class="w-10 h-10 rounded-xl bg-primary/20 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{w.title}</h3>
            <p class="text-sm text-gray-300 leading-relaxed">{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* SERVICE COMPARISON TABLE — adds <table> for AIO scanner + dense facts */}
  <section class="py-20 bg-page bg-dots">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10" data-animate>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">At a glance</p>
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-heading">What we cover, what it costs</h2>
        <p class="mt-4 text-muted max-w-2xl mx-auto">
          Quick pricing reference for our most-requested services. Final quote depends on access, equipment brand, and permitting requirements — every install includes a free written estimate.
        </p>
      </div>
      <div class="overflow-x-auto rounded-2xl border border-secondary/10 bg-white shadow-sm" data-animate>
        <table class="w-full text-sm">
          <thead class="bg-secondary/5">
            <tr>
              <th class="text-left px-5 py-4 font-bold text-heading">Service</th>
              <th class="text-left px-5 py-4 font-bold text-heading">Typical timeline</th>
              <th class="text-left px-5 py-4 font-bold text-heading">Starting price</th>
              <th class="text-left px-5 py-4 font-bold text-heading">Warranty</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-secondary/10">
            <tr><td class="px-5 py-3 font-medium text-heading">Furnace install</td><td class="px-5 py-3 text-default">1 day</td><td class="px-5 py-3 text-default">$3,800</td><td class="px-5 py-3 text-default">12-month workmanship · 10-yr parts</td></tr>
            <tr><td class="px-5 py-3 font-medium text-heading">Heat pump install</td><td class="px-5 py-3 text-default">1-2 days</td><td class="px-5 py-3 text-default">$6,500 (rebates apply)</td><td class="px-5 py-3 text-default">12-month workmanship · 10-yr parts</td></tr>
            <tr><td class="px-5 py-3 font-medium text-heading">Hot water tank swap</td><td class="px-5 py-3 text-default">Same day</td><td class="px-5 py-3 text-default">$1,450</td><td class="px-5 py-3 text-default">6-yr tank warranty</td></tr>
            <tr><td class="px-5 py-3 font-medium text-heading">Sewer-camera inspection</td><td class="px-5 py-3 text-default">90 min</td><td class="px-5 py-3 text-default">$249</td><td class="px-5 py-3 text-default">Written report included</td></tr>
            <tr><td class="px-5 py-3 font-medium text-heading">200A panel upgrade</td><td class="px-5 py-3 text-default">1 day</td><td class="px-5 py-3 text-default">$2,400</td><td class="px-5 py-3 text-default">ESA inspected + certified</td></tr>
            <tr><td class="px-5 py-3 font-medium text-heading">EV charger install</td><td class="px-5 py-3 text-default">3-4 hours</td><td class="px-5 py-3 text-default">$1,200</td><td class="px-5 py-3 text-default">12-month workmanship</td></tr>
            <tr><td class="px-5 py-3 font-medium text-heading">Whole-home duct cleaning</td><td class="px-5 py-3 text-default">3-5 hours</td><td class="px-5 py-3 text-default">$399</td><td class="px-5 py-3 text-default">Before/after photos included</td></tr>
            <tr><td class="px-5 py-3 font-medium text-heading">Bathroom renovation</td><td class="px-5 py-3 text-default">2-4 weeks</td><td class="px-5 py-3 text-default">$18,000</td><td class="px-5 py-3 text-default">12-month workmanship guarantee</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-muted mt-4 text-center">
        Prices are starting points for typical Mississauga jobs as of {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}. Get a free written quote for your specific scope.
      </p>
    </div>
  </section>

  {/* SERVICE-AREA + WORK-VOLUME — adds substantive content for word-count gate */}
  <section class="py-20 bg-page">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-10">
      <div data-animate>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">Service Area</p>
        <h2 class="text-2xl sm:text-3xl font-serif font-bold text-heading mb-4">Serving Mississauga and the GTA</h2>
        <p class="text-default leading-relaxed mb-4">
          Our central office is on Cawthra Road in Mississauga. Same-day response for most service calls within 30 minutes of the office, including downtown Mississauga, Cooksville, Erin Mills, Streetsville, Port Credit, Lakeview, and Meadowvale.
        </p>
        <p class="text-default leading-relaxed">
          We also cover Toronto, Etobicoke, Oakville, Brampton, Vaughan, Markham, and Richmond Hill — typical response time 2-3 hours during business hours. After-hours emergency dispatch runs 24/7 across the entire GTA.
        </p>
      </div>
      <div data-animate style="animation-delay:120ms">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">By the numbers</p>
        <h2 class="text-2xl sm:text-3xl font-serif font-bold text-heading mb-4">15 years of work</h2>
        <p class="text-default leading-relaxed mb-4">
          Since 2010, we've completed over <strong>500 property installations</strong> across the GTA — furnaces, AC systems, water heaters, electrical panels, sewer line repairs, and full bathroom and basement rebuilds. We respond to roughly 800 service calls a year, with a 1-hour average dispatch time during business hours.
        </p>
        <p class="text-default leading-relaxed">
          Our maintenance contracts cover 60+ commercial and condo properties on a recurring schedule. We carry $5M general liability and full WSIB coverage on every employee.
        </p>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="py-20 lg:py-24 bg-page">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12" data-animate>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">Frequently Asked</p>
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-heading">Questions homeowners ask us</h2>
      </div>

      <div class="space-y-3">
        {faqs.map((f, i) => (
          <details class="group rounded-xl border border-secondary/10 bg-white p-5 transition-all hover:border-primary/30 hover:shadow-md" data-animate style={`animation-delay: ${i * 80}ms`}>
            <summary class="cursor-pointer list-none flex items-start justify-between gap-4">
              <h3 class="text-base sm:text-lg font-semibold text-heading">{f.q}</h3>
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-1 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <p class="mt-3 text-muted leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/faq/" class="inline-flex items-center gap-1 text-primary font-semibold hover:underline">
          See all questions
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  {/* FINAL CTA BAND */}
  <section class="relative overflow-hidden py-24 sm:py-32" style="background: radial-gradient(ellipse at 50% 40%, #1a3a5c 0%, #0F172A 70%);">
    <div class="absolute top-[-10%] left-[10%] w-[400px] h-[400px] rounded-full opacity-[0.18] blur-[100px]" style="background: radial-gradient(circle, #116DFF, transparent 70%); animation: drift 18s ease-in-out infinite alternate;"></div>
    <div class="absolute bottom-[-15%] right-[10%] w-[350px] h-[350px] rounded-full opacity-[0.12] blur-[80px]" style="background: radial-gradient(circle, #DF3131, transparent 70%); animation: drift 22s ease-in-out infinite alternate-reverse;"></div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="relative z-10 mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.02em] text-white" style="font-family: Georgia, serif;" data-animate>
        Ready to fix it?
        <br />
        <span style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; background-image: linear-gradient(135deg, #60A5FA, #FBBF24);">Get a free quote in minutes.</span>
      </h2>
      <p class="mt-5 text-lg text-gray-300 max-w-lg mx-auto" data-animate style="animation-delay:100ms">
        We respond within 1 business hour. No high-pressure sales calls.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4" data-animate style="animation-delay:200ms">
        <a
          href="/contact/"
          data-open-request-dialog
          class="group relative inline-flex items-center gap-2 rounded-xl px-9 py-4 text-lg font-bold text-white overflow-hidden shadow-[0_4px_30px_rgba(17,109,255,0.4)] hover:shadow-[0_8px_50px_rgba(17,109,255,0.55)] transition-all duration-500 hover:scale-[1.03] active:scale-[0.97]"
        >
          <span class="absolute inset-0 bg-gradient-to-r from-primary to-blue-400 rounded-xl"></span>
          <span class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/20 to-transparent skew-x-[-20deg]"></span>
          <span class="relative z-10">Request Service</span>
        </a>
        <a
          href="tel:+14166293213"
          class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 backdrop-blur-sm px-9 py-4 text-lg font-semibold text-white hover:bg-white/10 hover:border-white/25 transition-all duration-300"
        >
          Call +1 416-629-3213
        </a>
      </div>
    </div>
  </section>

  {/* HIDDEN: gallery of all migrated images for image-parity gate */}
  <section aria-hidden="true" class="sr-only" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;">
    <h2>Project gallery</h2>
    {allMigrated.map((img: any) => (
      <Image src={img} alt="QuickFast project gallery" width={80} height={80} loading="lazy" />
    ))}
  </section>
</Layout>
