---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Pricing & Service Plans',
  description:
    'Flat-rate pricing for HVAC, plumbing and electrical service. Free written estimates on installations and renovations. No hidden fees.',
};

const tiers = [
  {
    name: 'Service Call',
    price: '$95',
    period: 'flat diagnostic',
    desc: 'Standard service-call fee for diagnosis and minor repair within Mississauga.',
    features: [
      'Diagnosis + written quote',
      'Up to 30 minutes on-site',
      'Service-call fee waived if you proceed with the work',
      '24/7 emergency rate: $145',
    ],
    cta: 'Book service',
    accent: false,
  },
  {
    name: 'Maintenance Plan',
    price: '$249',
    period: '/year',
    desc: 'Annual HVAC tune-up plus priority scheduling and discounted repair rates.',
    features: [
      'Annual furnace + AC tune-up',
      '15% discount on all repair work',
      'Priority scheduling — no service-call fee',
      'Same-day response on emergencies',
      'Auto-renewal, cancel anytime',
    ],
    cta: 'Start membership',
    accent: true,
  },
  {
    name: 'Installation',
    price: 'Free',
    period: 'written quote',
    desc: 'New installs and renovations get a free written estimate with itemized costs.',
    features: [
      'On-site evaluation',
      'Itemized written quote within 24 hours',
      'Equipment, labour and permits broken out',
      'No-obligation — quote valid 30 days',
      'Workmanship guarantee included',
    ],
    cta: 'Get a quote',
    accent: false,
  },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://quickfast.ca/' },
    { '@type': 'ListItem', position: 2, name: 'Pricing', item: 'https://quickfast.ca/pricing/' },
  ],
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb).replace(/</g, '\\u003c')} />
  </Fragment>

  <section class="relative min-h-[40vh] flex items-center overflow-hidden -mt-[72px]" style="background: linear-gradient(135deg, #112F5B 0%, #0a1f40 100%);">
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-6 text-center pt-32 pb-12">
      <p class="hero-fade text-xs font-bold uppercase tracking-[0.2em] text-blue-300 mb-3">Pricing</p>
      <h1 class="hero-fade text-4xl sm:text-5xl font-serif font-bold text-white" style="animation-delay:120ms">
        Honest pricing. <span class="block">No surprises on the invoice.</span>
      </h1>
      <p class="hero-fade mt-4 text-lg text-gray-300 max-w-xl mx-auto" style="animation-delay:280ms">
        Flat-rate diagnostic, transparent membership pricing, free written quotes on installs.
      </p>
    </div>
  </section>

  <section class="py-20 bg-page">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {tiers.map((t, i) => (
          <div class={`rounded-2xl p-8 border-2 ${t.accent ? 'border-primary bg-primary/5 shadow-xl shadow-primary/10' : 'border-secondary/10 bg-white'} transition-all hover:shadow-xl`} data-animate style={`animation-delay: ${i * 100}ms`}>
            {t.accent && <div class="text-xs font-bold uppercase tracking-widest text-primary mb-3">Most popular</div>}
            <h2 class="text-2xl font-serif font-bold text-heading">{t.name}</h2>
            <p class="text-muted mt-1 mb-6 text-sm">{t.desc}</p>
            <div class="flex items-baseline gap-1 mb-6">
              <span class="text-4xl font-serif font-bold text-heading">{t.price}</span>
              <span class="text-muted text-sm">{t.period}</span>
            </div>
            <ul class="space-y-3 mb-8 text-sm">
              {t.features.map((f) => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-default">{f}</span>
                </li>
              ))}
            </ul>
            <a href="/contact/" data-open-request-dialog class={t.accent ? 'btn-primary w-full text-center' : 'btn w-full text-center'}>{t.cta}</a>
          </div>
        ))}
      </div>

      <div class="mt-16 max-w-3xl mx-auto text-center" data-animate>
        <h2 class="text-2xl sm:text-3xl font-serif font-bold text-heading mb-4">Project pricing</h2>
        <p class="text-default leading-relaxed mb-4">
          Renovations, panel upgrades, water-heater swaps, EV-charger installs and similar capital projects are quoted per-project. Most quotes turn around within 24 hours of the on-site visit. No deposits required to receive a quote.
        </p>
        <p class="text-muted text-sm">
          Service prices effective {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}. Subject to change with 30 days' notice.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-secondary text-white text-center">
    <div class="max-w-2xl mx-auto px-4" data-animate>
      <h2 class="text-2xl font-serif font-bold mb-4">Need an after-hours quote?</h2>
      <p class="text-white/80 mb-6">Call our 24/7 line — we'll get a written quote to your inbox.</p>
      <a href="tel:+14166293213" class="btn-primary">+1 416-629-3213</a>
    </div>
  </section>
</Layout>
